# ─────────────────────────────────────────────────────────────────────────────
# Template do secrets.toml do Streamlit (login OIDC nativo — st.login).
# Copie para `.streamlit/secrets.toml` (gitignored) e preencha.
#
# COMO OBTER as credenciais do Google:
#   1. https://console.cloud.google.com → crie/selecione um projeto.
#   2. "APIs & Services" → "OAuth consent screen": tipo External, adicione seu
#      e-mail como test user (beta por convite).
#   3. "Credentials" → "Create Credentials" → "OAuth client ID" → Web application.
#   4. Authorized redirect URIs: adicione EXATAMENTE o redirect_uri abaixo
#      (local: http://localhost:8501/oauth2callback).
#   5. Copie Client ID e Client secret para cá.
#
# O redirect_uri precisa BATER com o registrado no Google. Em produção troque
# para a URL pública do app + /oauth2callback.
# ─────────────────────────────────────────────────────────────────────────────

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
# Segredo p/ assinar o cookie de sessão do Streamlit (não é o Google secret).
# Gere: python -c "import secrets; print(secrets.token_urlsafe(48))"
cookie_secret = "TROQUE_POR_UM_SEGREDO_FORTE"

[auth.google]
client_id = "SEU_CLIENT_ID.apps.googleusercontent.com"
client_secret = "SEU_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
