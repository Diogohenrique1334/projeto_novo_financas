# ─────────────────────────────────────────────────────────────────────────────
# Template de variáveis de ambiente. Copie para `.env` (gitignored) e preencha.
# Segredos SÓ via env — nada hardcoded (spec §9).
# ─────────────────────────────────────────────────────────────────────────────

# Banco SaaS — SEPARADO do banco pessoal do Diogo (spec §7). Postgres/Neon async.
# Ex.: postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=

# LLM de extração (OpenAI mantida; o que foi descontinuado é o Agente de Gastos).
OPENAI_API_KEY=

# Comunicação frontend ↔ backend
BACKEND_URL=http://localhost:8001
ALLOWED_ORIGINS=http://localhost:8501

# ─── Auth / autorização (Fases 2-3, ainda não implementadas) ─────────────────
# Bootstrap do admin: e-mails que nascem role=admin, status=approved (spec §3).
# Lista separada por vírgula.
ADMIN_EMAILS=diogohenrique1334@gmail.com

# Segredo HMAC compartilhado frontend↔backend (asserção interna / padrão BFF).
# Gere um forte, ex.: python -c "import secrets; print(secrets.token_urlsafe(48))"
# O MESMO valor precisa estar disponível para o frontend e para o backend.
INTERNAL_AUTH_SECRET=
AUTH_ASSERTION_TTL=300

# OIDC Google: NÃO vai aqui — o st.login nativo lê de .streamlit/secrets.toml.
# Veja .streamlit/secrets.toml.example.

# ─── Controle de custo (spec §9) ─────────────────────────────────────────────
LIMITE_DIARIO_UPLOAD=50
UPLOAD_MAX_MB=10

# Debug (SQL echo etc.)
DEBUG=false
